/* history.wxss - empty state and history list polish */

.history-page .page-header {
  padding-bottom: 24rpx;
}

.empty-card {
  padding: 20rpx 28rpx 34rpx;
}

.empty-action {
  width: 320rpx;
  height: 84rpx;
  margin-top: 28rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  display: block;
  margin: 0 auto 24rpx;
}

.history-toolbar {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}
