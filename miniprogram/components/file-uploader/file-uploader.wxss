/* file-uploader.wxss */
.uploader-wrap {
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-md);
  padding: 32px 16px;
  text-align: center;
  background: var(--color-surface-2);
}

.upload-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.upload-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-0);
  margin-bottom: 4px;
}

.upload-desc {
  font-size: 10px;
  font-weight: 600;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.file-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.file-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  background: var(--color-surface);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
}

.file-row.error {
  background: #fef2f2;
  border-color: #fecaca;
}

.file-icon {
  font-size: 18px;
  flex-shrink: 0;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-text-0);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta {
  font-size: 11px;
  color: var(--color-text-3);
  margin-top: 2px;
}

.file-error {
  font-size: 11px;
  color: var(--color-neg);
  margin-top: 2px;
}

.file-remove {
  font-size: 13px;
  color: var(--color-text-3);
  padding: 4px;
}
