<!-- history.wxml — 历史记录 -->

<view class="container">
  <!-- 加载 -->
  <view class="empty-state" wx:if="{{loading}}">
    <view class="empty-state-icon">⏳</view>
    <view class="empty-state-title">加载中...</view>
  </view>

  <!-- 空 -->
  <view class="empty-state" wx:elif="{{historyList.length === 0}}">
    <view class="empty-state-icon">📋</view>
    <view class="empty-state-title">暂无历史记录</view>
    <view class="empty-state-desc">完成的分析会显示在这里</view>
  </view>

  <!-- 列表 -->
  <block wx:else>
    <view style="text-align:right;margin-bottom:12px;">
      <button class="btn btn-danger btn-sm" bind:tap="clearAll">清空全部</button>
    </view>

    <view class="history-item {{item.status}}" wx:for="{{historyList}}" wx:key="taskId"
          bind:tap="viewDetail" data-task-id="{{item.taskId}}">
      <view class="history-header">
        <view>
          <text class="chip {{item.status === 'completed' ? 'chip-pos' : 'chip-neg'}}">
            {{item.status === 'completed' ? '已完成' : '失败'}}
          </text>
        </view>
        <text class="history-time">{{item.createdAt}}</text>
      </view>

      <view class="history-body" wx:if="{{item.resultSummary}}">
        <view class="history-stats">
          <text wx:if="{{item.resultSummary.total !== null}}" style="font-size:12px;color:var(--color-text-secondary);">
            {{item.resultSummary.total}} 条
          </text>
          <text class="chip chip-accent" wx:if="{{item.resultSummary.llm_enabled}}">AI 标注</text>
          <text class="chip chip-neg" wx:if="{{item.resultSummary.negative_rate !== null}}">
            负面 {{(item.resultSummary.negative_rate * 100).toFixed(0)}}%
          </text>
        </view>
      </view>

      <view class="history-error" wx:if="{{item.error}}">{{item.error}}</view>

      <view class="history-footer">
        <text class="link-text" wx:if="{{item.status === 'completed'}}">查看详情 ›</text>
        <text class="delete-btn" catch:tap="deleteItem" data-task-id="{{item.taskId}}">删除</text>
      </view>
    </view>
  </block>
</view>
