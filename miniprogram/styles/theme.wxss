/* ============================================================
   theme.wxss - global layout, cards, forms, buttons
   ============================================================ */

.container {
  min-height: 100vh;
  padding: 40rpx 32rpx calc(120rpx + env(safe-area-inset-bottom));
  background: var(--fp-bg);
}

.page-header {
  padding: 20rpx 2rpx 30rpx;
}

.page-title {
  font-size: 48rpx;
  line-height: 1.16;
  font-weight: 750;
  color: var(--fp-text-primary);
  letter-spacing: 0;
}

.page-desc {
  margin-top: 12rpx;
  max-width: 620rpx;
  font-size: 27rpx;
  line-height: 1.55;
  color: var(--fp-text-secondary);
}

.panel {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: var(--fp-surface);
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-lg);
  box-shadow: var(--fp-shadow-card);
}

.panel-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--fp-text-primary);
}

.panel-sub {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 500;
  color: var(--fp-text-tertiary);
}

.section-note {
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--fp-text-secondary);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 650;
  transition: opacity var(--transition-fast), transform var(--transition-fast);
}

.btn::after {
  border: 0;
}

.btn:active {
  opacity: 0.82;
}

.btn-primary {
  color: #fbfdff;
  background: var(--fp-accent);
  box-shadow: 0 10rpx 24rpx rgba(47, 109, 246, 0.24);
}

.btn-primary[disabled],
.btn-disabled {
  color: var(--fp-text-tertiary);
  background: #edf1f7;
  box-shadow: none;
}

.btn-ghost {
  color: var(--fp-text-primary);
  background: var(--fp-surface);
  border: 1rpx solid var(--fp-border);
}

.btn-danger {
  color: var(--fp-danger);
  background: var(--fp-danger-soft);
}

.btn-sm {
  min-height: 60rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  border-radius: 16rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 650;
  color: var(--fp-text-primary);
}

.form-input {
  width: 100%;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: 18rpx;
  color: var(--fp-text-primary);
  background: var(--fp-surface-soft);
  font-size: 28rpx;
  line-height: 76rpx;
}

.form-input-placeholder {
  color: var(--fp-text-tertiary);
}

.form-hint {
  margin-top: 10rpx;
  color: var(--fp-text-tertiary);
  font-size: 23rpx;
  line-height: 1.45;
}

.segmented-control {
  display: flex;
  min-height: 76rpx;
  padding: 6rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: 22rpx;
  background: var(--fp-surface-soft);
}

.seg-item {
  flex: 1;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 17rpx;
  color: var(--fp-text-secondary);
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 650;
}

.seg-item.active {
  color: #fbfdff;
  background: var(--fp-accent);
  box-shadow: 0 6rpx 16rpx rgba(47, 109, 246, 0.2);
}

.setting-row {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 0;
}

.setting-row-left {
  min-width: 0;
  flex: 1;
}

.setting-row-title {
  color: var(--fp-text-primary);
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 650;
}

.setting-row-desc {
  margin-top: 6rpx;
  color: var(--fp-text-secondary);
  font-size: 24rpx;
  line-height: 1.45;
}

.divider {
  height: 1rpx;
  margin: 18rpx 0 28rpx;
  background: var(--fp-border);
}

.progress-bar {
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9edf5;
}

.progress-bar-fill {
  height: 100%;
  min-width: 8rpx;
  border-radius: 999rpx;
  background: var(--fp-accent);
  transition: width var(--transition-normal);
}

.empty-state {
  padding: 56rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-state-icon {
  margin-bottom: 20rpx;
  font-size: 54rpx;
  line-height: 1;
}

.empty-state-title {
  color: var(--fp-text-primary);
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

.empty-state-desc {
  margin-top: 10rpx;
  max-width: 520rpx;
  color: var(--fp-text-secondary);
  font-size: 25rpx;
  line-height: 1.55;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 650;
  white-space: nowrap;
}

.chip-info { color: var(--fp-info); background: var(--fp-info-soft); }
.chip-pos { color: var(--fp-success); background: var(--fp-success-soft); }
.chip-neg { color: var(--fp-danger); background: var(--fp-danger-soft); }
.chip-warn { color: var(--fp-warning); background: var(--fp-warning-soft); }
.chip-neutral { color: var(--fp-text-secondary); background: #eef2f7; }
.chip-brand,
.chip-accent { color: var(--fp-accent); background: var(--fp-accent-soft); }

.link-text {
  color: var(--fp-accent);
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 650;
}
