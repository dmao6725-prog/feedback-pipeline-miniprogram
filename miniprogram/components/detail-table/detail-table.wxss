/* detail-table.wxss */
.table-scroll {
  width: 100%;
}

.table-wrap {
  min-width: 800px;
}

.table-header {
  display: flex;
  background: var(--color-surface-2);
  border-bottom: 2px solid var(--color-border);
}

.table-row {
  display: flex;
  border-bottom: 1px solid var(--color-border-soft);
}

.table-row.highlight {
  background: #eff6ff;
}

.table-cell {
  flex: 1;
  min-width: 100px;
  max-width: 250px;
  padding: 8px 10px;
  font-size: 11px;
  color: var(--color-text-1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  border-right: 1px solid var(--color-border-soft);
}

.header-cell {
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-2);
}

.table-row:nth-child(even) {
  background: var(--color-surface);
}
