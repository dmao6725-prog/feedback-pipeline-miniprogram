/* file-uploader.wxss */
.uploader-wrap {
  padding: 56rpx 28rpx;
  border: 2rpx dashed var(--fp-border-strong);
  border-radius: var(--fp-radius-lg);
  text-align: center;
  background: var(--fp-surface-soft);
}

.upload-icon {
  width: 112rpx;
  height: 112rpx;
  display: block;
  margin: 0 auto 20rpx;
}

.upload-title {
  color: var(--fp-text-primary);
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.upload-desc {
  color: var(--fp-text-tertiary);
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 600;
}

.file-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.file-row {
  min-height: 92rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-md);
  background: var(--fp-surface);
}

.file-row.error {
  border-color: #ffd0cc;
  background: var(--fp-danger-soft);
}

.file-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: var(--fp-danger);
  background: var(--fp-accent-soft);
  font-size: 26rpx;
  font-weight: 800;
}

.file-status-image {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.file-info {
  min-width: 0;
  flex: 1;
  text-align: left;
}

.file-name {
  overflow: hidden;
  color: var(--fp-text-primary);
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta,
.file-error {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.35;
}

.file-meta {
  color: var(--fp-text-tertiary);
}

.file-error {
  color: var(--fp-danger);
}

.file-remove {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: var(--fp-text-tertiary);
  background: var(--fp-surface-soft);
  font-size: 28rpx;
}
