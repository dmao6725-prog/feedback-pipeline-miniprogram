<!-- result.wxml — 结果看板 -->

<!-- 加载 -->
<view class="container" wx:if="{{loading}}">
  <view class="empty-state"><view class="loading-mark"></view><view class="empty-state-title">加载中...</view></view>
</view>

<!-- 错误 -->
<view class="container" wx:elif="{{error}}">
  <view class="panel error-panel">
    <view class="error-icon">!</view>
    <view class="error-text">{{error}}</view>
    <view style="text-align:center;margin-top:12px;">
      <button class="btn btn-ghost btn-sm" bind:tap="loadResult">重试</button>
    </view>
  </view>
</view>

<!-- 结果 -->
<view class="container" wx:elif="{{result}}">
  <!-- Tab -->
  <view class="segmented-control" style="margin-bottom: 14px;">
    <view class="seg-item {{activeTab === 'overview' ? 'active' : ''}}" bind:tap="switchTab" data-tab="overview">概览</view>
    <view class="seg-item {{activeTab === 'samples' ? 'active' : ''}}" bind:tap="switchTab" data-tab="samples">样本</view>
  </view>

  <!-- ====== 概览 ====== -->
  <block wx:if="{{activeTab === 'overview'}}">
    <!-- KPI -->
    <view class="kpi-grid">
      <view class="kpi-card">
        <view class="kpi-label">样本总数</view>
        <view class="kpi-value" style="color:#2563eb;">{{result.overviewView.totalText}}</view>
      </view>
      <view class="kpi-card" wx:if="{{result.overviewView.hasNegativeRate}}">
        <view class="kpi-label">负面率</view>
        <view class="kpi-value" style="color:#ef4444;">{{result.overviewView.negativeRateText}}</view>
        <view class="kpi-sub" wx:if="{{result.overviewView.hasNegativeCount}}">{{result.overviewView.negativeCountText}}</view>
      </view>
      <view class="kpi-card" wx:if="{{result.overviewView.hasHighSeverityRate}}">
        <view class="kpi-label">高严重度</view>
        <view class="kpi-value" style="color:#f59e0b;">{{result.overviewView.highSeverityRateText}}</view>
        <view class="kpi-sub" wx:if="{{result.overviewView.hasHighSeverityCount}}">{{result.overviewView.highSeverityCountText}}</view>
      </view>
      <view class="kpi-card" wx:if="{{result.overviewView.hasAvgRating}}">
        <view class="kpi-label">Play 平均分</view>
        <view class="kpi-value" style="color:#6366f1;">{{result.overviewView.avgRatingText}}</view>
      </view>
    </view>

    <!-- 数据来源 -->
    <view class="panel" wx:if="{{result.hasPlatforms}}">
      <view class="panel-title"><text>数据来源</text></view>
      <view class="source-list">
        <block wx:for="{{result.meta.platforms}}" wx:key="code">
          <view class="source-item">
            <text class="source-label">{{item.label}}</text>
            <text class="source-count">{{item.count}} 条</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 决策摘要 -->
    <view class="panel" wx:if="{{result.hasExecutiveSummary}}">
      <view class="panel-title">
        <text>决策摘要</text>
        <text class="chip chip-accent">AI</text>
      </view>
      <view style="font-size:13px;color:var(--color-text-secondary);line-height:1.7;">
        {{result.executiveSummaryText}}
      </view>
    </view>

    <!-- 议题分布 -->
    <view class="panel" wx:if="{{result.hasTopics}}">
      <view class="panel-title">
        <text>议题分布</text>
        <text class="panel-sub">{{result.topicCountText}}</text>
      </view>
      <view class="topic-list">
        <block wx:for="{{result.topicsView}}" wx:key="topic">
          <view class="topic-row">
            <view class="topic-name">{{item.topic}}</view>
            <view class="topic-bar-wrap">
              <view class="topic-bar" style="width:{{item.widthText}}; background:{{item.barColor}};"></view>
            </view>
            <view class="topic-counts">{{item.countText}} · {{item.shareText}}</view>
          </view>
        </block>
      </view>
      <view wx:if="{{result.hasTopicSummary}}" style="font-size:12px;color:var(--color-text-tertiary);margin-top:10px;">{{result.topicSummaryText}}</view>
    </view>

    <!-- 情感分布 -->
    <view class="panel" wx:if="{{result.hasSentiments}}">
      <view class="panel-title">情感分布</view>
      <view class="bar-list">
        <block wx:for="{{result.sentimentBarsView}}" wx:key="name">
          <view class="bar-item">
            <view class="bar-label" style="color:{{item.color}};">{{item.name}}</view>
            <view class="bar-wrap">
              <view class="bar-fill" style="width:{{item.widthText}}; background:{{item.color}};"></view>
            </view>
            <view class="bar-count">{{item.countText}}</view>
          </view>
        </block>
      </view>
    </view>

    <!-- 月度趋势 -->
    <view class="panel" wx:if="{{result.hasTrend}}">
      <view class="panel-title">
        <text>月度趋势</text>
        <text class="panel-sub">{{result.trendCountText}}</text>
      </view>
      <view class="trend-list">
        <block wx:for="{{result.trendView}}" wx:key="yearMonth">
          <view class="trend-row">
            <view class="trend-month">{{item.yearMonth}}</view>
            <view class="trend-count-wrap">
              <view class="trend-bar" style="width:{{item.widthText}};"></view>
            </view>
            <view class="trend-counts">{{item.countText}}<text wx:if="{{item.hasNegativeRate}}"> · 负面 {{item.negativeRateText}}</text></view>
          </view>
        </block>
      </view>
    </view>

    <!-- 代表性样本 -->
    <view class="panel" wx:if="{{result.hasRows}}">
      <view class="panel-title">
        <text>代表性样本</text>
        <text class="link-text" bind:tap="switchTab" data-tab="samples">查看全部 ›</text>
      </view>
      <block wx:for="{{result.sampleRows}}" wx:key="rowId">
        <view class="sample-card">
          <view class="sample-header">
            <view class="sample-title">{{item.sampleTitle}}</view>
            <view class="sample-chips">
              <text class="chip chip-info" wx:if="{{item.hasTopic}}">{{item.topicText}}</text>
              <text class="chip chip-pos" wx:if="{{item.isPositive}}">{{item.sentimentText}}</text>
              <text class="chip chip-neg" wx:if="{{item.isNegative}}">{{item.sentimentText}}</text>
              <text class="chip chip-warn" wx:if="{{item.isMixed}}">{{item.sentimentText}}</text>
            </view>
          </view>
          <view class="sample-summary">{{item.summaryText}}</view>
        </view>
      </block>
    </view>

    <!-- 导出 -->
    <view class="export-bar" wx:if="{{result.hasRows}}">
      <button class="btn btn-ghost" bind:tap="exportCSV" style="flex:1;">导出 CSV</button>
    </view>
  </block>

  <!-- ====== 样本 ====== -->
  <block wx:if="{{activeTab === 'samples'}}">
    <!-- 筛选 -->
    <view class="panel">
      <view class="filter-row">
        <picker mode="selector" range="{{topicOptions}}" value="{{topicIdx}}" bindchange="onTopicChange">
          <view class="filter-btn">议题：{{selectedTopicText}} ▼</view>
        </picker>
        <picker mode="selector" range="{{sentimentOptions}}" value="{{sentimentIdx}}" bindchange="onSentimentChange">
          <view class="filter-btn">情感：{{selectedSentimentText}} ▼</view>
        </picker>
        <picker mode="selector" range="{{severityOptions}}" value="{{severityIdx}}" bindchange="onSeverityChange">
          <view class="filter-btn">严重：{{selectedSeverityText}} ▼</view>
        </picker>
      </view>
      <view class="filter-toggle" bind:tap="toggleMeaningful">
        <switch checked="{{meaningfulOnly}}" color="#2563eb" style="transform:scale(0.8);" />
        <text>仅看有核心含义/可落地性</text>
      </view>
    </view>

    <!-- 空结果 -->
    <view class="panel" wx:if="{{filteredRows.length === 0}}">
      <view style="text-align:center;padding:30px;color:var(--color-text-tertiary);font-size:13px;">
        没有符合条件的样本，请调整筛选条件。
      </view>
    </view>

    <!-- 样本列表 -->
    <block wx:for="{{filteredRows}}" wx:key="rowId" wx:for-item="row">
      <view class="sample-card">
        <view class="sample-header">
          <view class="sample-title">{{row.sampleTitle}}</view>
          <view class="sample-chips">
            <text class="chip chip-info" wx:if="{{row.hasTopic}}">{{row.topicText}}</text>
            <text class="chip chip-pos" wx:if="{{row.isPositive}}">{{row.sentimentText}}</text>
            <text class="chip chip-neg" wx:if="{{row.isNegative}}">{{row.sentimentText}}</text>
            <text class="chip chip-warn" wx:if="{{row.isMixed}}">{{row.sentimentText}}</text>
            <text class="chip chip-neutral" wx:if="{{row.isNeutral}}">{{row.sentimentText}}</text>
            <text class="chip chip-neg" wx:if="{{row.isSevere}}">严重</text>
          </view>
        </view>
        <view class="sample-summary">{{row.summaryText}}</view>
        <view class="sample-detail" wx:if="{{row.isExpanded}}">
          <view class="detail-field" wx:if="{{row.hasCoreMeaning}}">
            <view class="detail-label">核心含义</view>
            <view class="detail-value">{{row.coreMeaningText}}</view>
          </view>
          <view class="detail-field" wx:if="{{row.hasUserIntent}}">
            <view class="detail-label">用户意图</view>
            <view class="detail-value">{{row.userIntentText}}</view>
          </view>
          <view class="detail-field" wx:if="{{row.hasActionability}}">
            <view class="detail-label">可落地性</view>
            <view class="detail-value">{{row.actionabilityText}}</view>
          </view>
          <view class="detail-field" wx:if="{{row.hasEvidence}}">
            <view class="detail-label">证据原文</view>
            <view class="detail-value quote">{{row.evidenceText}}</view>
          </view>
          <view class="detail-field">
            <view class="detail-label">来源</view>
            <view class="detail-value">{{row.sourceText}}</view>
          </view>
        </view>
        <view class="sample-footer">
          <text class="expand-hint" bind:tap="toggleSample" data-id="{{row.rowId}}">{{row.expandText}}</text>
        </view>
      </view>
    </block>
  </block>
</view>
