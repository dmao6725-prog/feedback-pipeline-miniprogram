/* app.wxss */
page {
  --color-brand: #2563eb;
  --color-brand-light: #3b82f6;
  --color-brand-bg: #eff6ff;
  --color-pos: #10b981;
  --color-neg: #ef4444;
  --color-warn: #f59e0b;
  --color-info: #3b82f6;
  --color-neutral: #9ca3af;
  --color-text-0: #111827;
  --color-text-1: #374151;
  --color-text-2: #6b7280;
  --color-text-3: #9ca3af;
  --color-bg: #f5f5f5;
  --color-surface: #ffffff;
  --color-surface-2: #f9fafb;
  --color-border: #e5e7eb;
  --color-border-soft: #f3f4f6;
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
  color: var(--color-text-0);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

.container {
  padding: 16px;
}

/* Panel 卡片 */
.panel {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}

.panel-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-0);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* KPI 卡片 */
.kpi-card {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.kpi-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.kpi-value {
  font-size: 28px;
  font-weight: 700;
  margin: 4px 0;
}

.kpi-sub {
  font-size: 11px;
  color: var(--color-text-2);
}

/* Chip */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 500;
}

.chip-info { background: #eff6ff; color: #2563eb; }
.chip-pos { background: #ecfdf5; color: #059669; }
.chip-neg { background: #fef2f2; color: #dc2626; }
.chip-warn { background: #fffbeb; color: #d97706; }
.chip-neutral { background: #f9fafb; color: #6b7280; }
.chip-brand { background: #eff6ff; color: #2563eb; }

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 20px;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 600;
  border: none;
  outline: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-brand), var(--color-brand-light));
  color: #fff;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-ghost {
  background: var(--color-surface-2);
  color: var(--color-text-1);
  border: 1px solid var(--color-border);
}

.btn-danger {
  background: #fef2f2;
  color: var(--color-neg);
}

/* 表单 */
.form-group {
  margin-bottom: 14px;
}

.form-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 13px;
  color: var(--color-text-0);
  background: var(--color-surface-2);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--color-brand);
  outline: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  color: var(--color-text-2);
}

.empty-state-icon {
  font-size: 48px;
  margin-bottom: 12px;
  opacity: 0.6;
}

.empty-state-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-0);
  margin-bottom: 6px;
}

.empty-state-desc {
  font-size: 12px;
  color: var(--color-text-3);
}

/* 进度条 */
.progress-bar {
  height: 8px;
  border-radius: 4px;
  background: var(--color-surface-2);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(135deg, var(--color-brand), var(--color-brand-light));
  transition: width 0.3s ease;
}
