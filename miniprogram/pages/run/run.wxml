<!-- run.wxml — 分析页：文件选择、参数配置、启动分析 -->

<view class="container">
  <!-- 标题 -->
  <view class="page-header">
    <view class="page-title">反馈分析</view>
    <view class="page-desc">导入反馈数据，自动清洗、标注并生成分析看板</view>
  </view>

  <!-- 文件选择区 -->
  <view class="panel">
    <view class="panel-title">
      <text>输入文件</text>
      <text class="panel-sub">{{fileCountText}}</text>
    </view>

    <view class="upload-zone" bind:tap="chooseFile" wx:if="{{files.length === 0}}">
      <view class="upload-zone-icon">+</view>
      <view class="upload-zone-title">点击选择文件</view>
      <view class="upload-zone-desc">TXT · MD · CSV · TSV · JSON · JSONL · XML · HTML</view>
    </view>

    <view class="file-list" wx:if="{{files.length > 0}}">
      <view class="file-row {{item.status}}" wx:for="{{files}}" wx:key="id">
        <view class="file-row-left">
          <view class="file-status-icon">{{item.statusIcon}}</view>
          <view class="file-row-info">
            <view class="file-row-name">{{item.name}}</view>
            <view class="file-row-meta" wx:if="{{item.status === 'ok'}}">{{item.metaText}}</view>
            <view class="file-row-error" wx:if="{{item.status === 'error'}}">{{item.error}}</view>
          </view>
        </view>
        <view class="file-row-right" bind:tap="removeFile" data-index="{{index}}">✕</view>
      </view>
      <view class="add-more" bind:tap="chooseFile" wx:if="{{files.length < 5}}">+ 添加文件</view>
    </view>
  </view>

  <!-- 参数区 -->
  <view class="panel">
    <view class="panel-title">
      <text>运行参数</text>
      <text class="panel-sub">单次最多 5 个文件</text>
    </view>

    <view class="form-group">
      <view class="form-label">分析主题 / 场景</view>
      <input class="form-input" placeholder="例如：RedNote 用户反馈"
             value="{{contextText}}" bindinput="onContextInput" />
    </view>

    <view class="form-group">
      <view class="form-label">模型</view>
      <view class="segmented-control">
        <view class="seg-item {{model === 'deepseek-v4-flash' ? 'active' : ''}}"
              bind:tap="selectModel" data-model="deepseek-v4-flash">Flash 快速</view>
        <view class="seg-item {{model === 'deepseek-v4-pro' ? 'active' : ''}}"
              bind:tap="selectModel" data-model="deepseek-v4-pro">Pro 高质量</view>
      </view>
    </view>

    <view class="setting-row cleaning-row" bind:tap="toggleNoLLM">
      <view class="setting-row-left">
        <view class="setting-row-title">仅清洗 / 启发式统计</view>
        <view class="setting-row-desc">不调用 DeepSeek，仅做文本清洗和基础统计</view>
      </view>
      <switch checked="{{noLLM}}" color="#2563eb" />
    </view>

    <button class="btn btn-primary btn-run" bind:tap="runAnalysis"
            disabled="{{!canRun}}" loading="{{isRunning}}">
      {{runButtonText}}
    </button>
  </view>

  <!-- 进度面板 -->
  <view class="panel" wx:if="{{isRunning}}">
    <view class="panel-title">
      <text>运行中</text>
      <text class="panel-sub">{{progress}}%</text>
    </view>
    <view class="progress-bar">
      <view class="progress-bar-fill" style="width: {{progress}}%;"></view>
    </view>
    <view class="progress-message">
      {{statusMessage}}
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="panel error-panel" wx:if="{{errorMessage}}">
    <view class="error-icon">!</view>
    <view class="error-text">{{errorMessage}}</view>
    <view style="text-align: center; margin-top: 12px;">
      <button class="btn btn-ghost btn-sm" bind:tap="dismissError">关闭</button>
    </view>
  </view>

  <!-- 最近结果 -->
  <view class="panel" wx:if="{{lastTaskId && !isRunning && !errorMessage}}">
    <view class="panel-title">
      <text>最近分析结果</text>
      <navigator url="/pages/result/result?taskId={{lastTaskId}}" class="link-text">查看完整看板 ›</navigator>
    </view>
  </view>
</view>
