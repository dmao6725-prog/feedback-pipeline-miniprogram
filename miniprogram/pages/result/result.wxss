/* result.wxss — 结果看板样式 */

/* Tab bar */
.tab-bar {
  margin-bottom: 12px;
}

/* KPI 网格 */
.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 12px;
}

.kpi-card {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: 16px 14px;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.kpi-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}

.kpi-value {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.1;
}

.kpi-sub {
  font-size: 11px;
  color: var(--color-text-2);
  margin-top: 4px;
}

/* 来源列表 */
.source-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.source-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  background: var(--color-surface-2);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
}

.source-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--color-text-0);
}

.source-count {
  font-size: 11px;
  color: var(--color-text-3);
}

/* 摘要 */
.summary-text {
  font-size: 13px;
  color: var(--color-text-1);
  line-height: 1.7;
}

/* 议题分布 */
.topic-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.topic-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.topic-name {
  font-size: 12px;
  color: var(--color-text-1);
  width: 80px;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topic-bar-wrap {
  flex: 1;
  height: 8px;
  background: var(--color-surface-2);
  border-radius: 4px;
  overflow: hidden;
}

.topic-bar {
  height: 100%;
  border-radius: 4px;
  min-width: 2px;
}

.topic-counts {
  font-size: 11px;
  color: var(--color-text-3);
  width: 80px;
  text-align: right;
  flex-shrink: 0;
}

.topic-summary-text {
  font-size: 12px;
  color: var(--color-text-2);
  margin-top: 8px;
}

/* 情感分布 */
.bar-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.bar-item {
  display: flex;
  align-items: center;
  gap: 10px;
}

.bar-label {
  font-size: 12px;
  font-weight: 500;
  width: 40px;
}

.bar-wrap {
  flex: 1;
  height: 20px;
  background: var(--color-surface-2);
  border-radius: 4px;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 4px;
  min-width: 2px;
}

.bar-count {
  font-size: 11px;
  color: var(--color-text-3);
  width: 36px;
  text-align: right;
}

/* 趋势 */
.trend-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.trend-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.trend-month {
  font-size: 11px;
  color: var(--color-text-2);
  width: 70px;
  flex-shrink: 0;
}

.trend-count-wrap {
  flex: 1;
  height: 6px;
  background: var(--color-surface-2);
  border-radius: 3px;
  overflow: hidden;
}

.trend-bar {
  height: 100%;
  background: var(--color-brand);
  border-radius: 3px;
  min-width: 2px;
}

.trend-counts {
  font-size: 11px;
  color: var(--color-text-3);
  width: 130px;
  text-align: right;
  flex-shrink: 0;
}

/* 样本卡片 */
.sample-card {
  background: var(--color-surface-2);
  border-radius: var(--radius-md);
  padding: 14px;
  margin-bottom: 10px;
  border: 1px solid var(--color-border);
}

.sample-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.sample-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-0);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sample-chips {
  display: flex;
  gap: 4px;
  flex-shrink: 0;
  flex-wrap: wrap;
}

.sample-summary {
  font-size: 13px;
  color: var(--color-text-1);
  line-height: 1.6;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.sample-detail {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--color-border);
}

.detail-field {
  margin-bottom: 8px;
}

.detail-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 3px;
}

.detail-value {
  font-size: 12px;
  color: var(--color-text-1);
  line-height: 1.5;
}

.detail-value.quote {
  background: var(--color-bg);
  padding: 10px;
  border-radius: var(--radius-md);
  border-left: 3px solid var(--color-brand);
  font-style: italic;
}

.sample-footer {
  margin-top: 8px;
  text-align: right;
}

.expand-hint {
  font-size: 11px;
  color: var(--color-brand);
}

/* 筛选栏 */
.filter-row {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.filter-btn {
  padding: 6px 12px;
  font-size: 12px;
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: 100px;
  color: var(--color-text-1);
}

.filter-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  background: var(--color-surface-2);
  border-radius: var(--radius-md);
  font-size: 12px;
  color: var(--color-text-1);
}

/* 导出 */
.export-bar {
  padding: 16px;
  display: flex;
  gap: 8px;
}

/* 面板小字 */
.panel-sub {
  font-size: 11px;
  color: var(--color-text-3);
}

/* 错误 */
.error-panel {
  background: #fef2f2;
  border: 1px solid #fecaca;
}

.error-text {
  font-size: 13px;
  color: var(--color-neg);
  text-align: center;
  margin-top: 8px;
}
