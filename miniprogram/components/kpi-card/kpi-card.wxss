/* kpi-card.wxss */
.kpi-card-wrap {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: 16px 14px;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.kpi-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}

.kpi-value {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.1;
}

.kpi-sub {
  font-size: 11px;
  color: var(--color-text-2);
  margin-top: 4px;
}
