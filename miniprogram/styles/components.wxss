/* ============================================================
   components.wxss - shared product UI components
   ============================================================ */

.upload-zone {
  min-height: 260rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 34rpx 28rpx;
  border: 2rpx dashed var(--fp-border-strong);
  border-radius: var(--fp-radius-lg);
  text-align: center;
  background: var(--fp-surface-soft);
}

.upload-zone:active {
  border-color: var(--fp-accent);
  background: var(--fp-accent-soft);
}

.upload-zone.compact {
  min-height: 86rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
}

.upload-zone-icon {
  margin-bottom: 16rpx;
  color: var(--fp-accent);
  font-size: 44rpx;
  line-height: 1;
}

.upload-zone-title {
  color: var(--fp-text-primary);
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.upload-zone-desc {
  margin-top: 10rpx;
  color: var(--fp-text-tertiary);
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 600;
}

.file-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.file-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 92rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-md);
  background: var(--fp-surface-soft);
}

.file-row.error {
  border-color: #ffd0cc;
  background: var(--fp-danger-soft);
}

.file-row-left {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.file-status-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: var(--fp-accent);
  background: var(--fp-accent-soft);
  font-size: 26rpx;
}

.file-row.error .file-status-icon {
  color: var(--fp-danger);
  background: #ffe4e1;
}

.file-row-info {
  min-width: 0;
  flex: 1;
}

.file-row-name {
  overflow: hidden;
  color: var(--fp-text-primary);
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-row-meta,
.file-row-error {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.35;
}

.file-row-meta {
  color: var(--fp-text-tertiary);
}

.file-row-error {
  color: var(--fp-danger);
}

.file-row-right {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: var(--fp-text-tertiary);
  background: var(--fp-surface);
  font-size: 28rpx;
}

.add-more {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed var(--fp-accent);
  border-radius: var(--fp-radius-md);
  color: var(--fp-accent);
  background: var(--fp-accent-soft);
  font-size: 26rpx;
  font-weight: 650;
}

.sample-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-md);
  background: var(--fp-surface);
  box-shadow: var(--fp-shadow-soft);
}

.sample-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.sample-title {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: var(--fp-text-primary);
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sample-chips {
  flex-shrink: 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  max-width: 310rpx;
}

.sample-summary {
  color: var(--fp-text-secondary);
  font-size: 25rpx;
  line-height: 1.65;
  word-break: break-word;
}

.sample-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--fp-border);
}

.sample-footer {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.expand-hint {
  color: var(--fp-accent);
  font-size: 24rpx;
  font-weight: 650;
}

.detail-field {
  margin-bottom: 18rpx;
}

.detail-field:last-child {
  margin-bottom: 0;
}

.detail-label {
  margin-bottom: 6rpx;
  color: var(--fp-text-tertiary);
  font-size: 22rpx;
  font-weight: 650;
}

.detail-value {
  color: var(--fp-text-secondary);
  font-size: 24rpx;
  line-height: 1.55;
}

.detail-value.quote {
  padding: 16rpx 18rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-sm);
  background: var(--fp-surface-soft);
}

.topic-list,
.bar-list,
.trend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.topic-row,
.bar-item,
.trend-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.topic-name {
  width: 150rpx;
  flex-shrink: 0;
  overflow: hidden;
  color: var(--fp-text-secondary);
  font-size: 24rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topic-bar-wrap,
.trend-count-wrap {
  flex: 1;
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9edf5;
}

.topic-bar,
.trend-bar {
  height: 100%;
  min-width: 6rpx;
  border-radius: 999rpx;
}

.topic-counts,
.trend-counts,
.bar-count {
  min-width: 88rpx;
  flex-shrink: 0;
  color: var(--fp-text-tertiary);
  font-size: 22rpx;
  line-height: 1.35;
  text-align: right;
}

.bar-label {
  width: 64rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 650;
}

.bar-wrap {
  flex: 1;
  height: 26rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9edf5;
}

.bar-fill {
  height: 100%;
  min-width: 6rpx;
  border-radius: 999rpx;
}

.trend-month {
  width: 126rpx;
  flex-shrink: 0;
  color: var(--fp-text-tertiary);
  font-size: 22rpx;
  line-height: 1.35;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.filter-btn {
  min-height: 58rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid var(--fp-border);
  border-radius: 999rpx;
  color: var(--fp-text-secondary);
  background: var(--fp-surface);
  font-size: 24rpx;
  font-weight: 650;
}

.filter-toggle {
  min-height: 82rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-md);
  color: var(--fp-text-secondary);
  background: var(--fp-surface-soft);
  font-size: 24rpx;
}

.history-item {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-lg);
  background: var(--fp-surface);
  box-shadow: var(--fp-shadow-card);
}

.history-item.failed {
  background: #fff9f8;
  border-color: #ffd0cc;
}

.history-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.history-title {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: var(--fp-text-primary);
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  color: var(--fp-text-tertiary);
  font-size: 23rpx;
  line-height: 1.35;
}

.history-body {
  margin-top: 14rpx;
}

.history-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.history-error {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: var(--fp-radius-sm);
  color: var(--fp-danger);
  background: var(--fp-danger-soft);
  font-size: 24rpx;
  line-height: 1.5;
}

.history-footer {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--fp-border);
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
}

.delete-btn {
  color: var(--fp-danger);
  font-size: 25rpx;
  font-weight: 650;
}

.error-panel {
  border-color: #ffd0cc;
  background: var(--fp-danger-soft);
}

.error-text {
  color: var(--fp-danger);
  font-size: 25rpx;
  line-height: 1.55;
  text-align: center;
}

.export-bar {
  padding: 24rpx 0 0;
}

.api-guide {
  margin-top: 16rpx;
  padding: 20rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-md);
  background: var(--fp-surface-soft);
}

.guide-step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.guide-step:last-child {
  margin-bottom: 0;
}

.guide-step-num {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #fbfdff;
  background: var(--fp-accent);
  font-size: 22rpx;
  font-weight: 700;
}

.guide-step-text {
  padding-top: 2rpx;
  color: var(--fp-text-secondary);
  font-size: 25rpx;
  line-height: 1.5;
}

.disclaimer {
  padding: 20rpx 10rpx 0;
  color: var(--fp-text-tertiary);
  font-size: 22rpx;
  line-height: 1.55;
  text-align: center;
}

.source-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.source-item {
  min-height: 56rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-sm);
  background: var(--fp-surface-soft);
}

.source-label {
  color: var(--fp-text-primary);
  font-size: 24rpx;
  font-weight: 650;
}

.source-count {
  color: var(--fp-text-tertiary);
  font-size: 22rpx;
}
