/* ============================================================
   tokens.wxss - FeedbackPipeline mini program design tokens
   Cross-platform Soft Surface system. No glass effects.
   ============================================================ */

page {
  --fp-bg: #f3f6fa;
  --fp-surface: #ffffff;
  --fp-surface-soft: #f8fafd;
  --fp-text-primary: #111827;
  --fp-text-secondary: #667085;
  --fp-text-tertiary: #98a2b3;
  --fp-border: #e4eaf2;
  --fp-border-strong: #d7deea;
  --fp-accent: #2f6df6;
  --fp-accent-strong: #2458d6;
  --fp-accent-soft: #eaf1ff;
  --fp-success: #12b76a;
  --fp-success-soft: #ecfdf3;
  --fp-warning: #f79009;
  --fp-warning-soft: #fff7e8;
  --fp-danger: #f04438;
  --fp-danger-soft: #fff0ef;
  --fp-info: #6172f3;
  --fp-info-soft: #eef4ff;
  --fp-radius-sm: 12rpx;
  --fp-radius-md: 20rpx;
  --fp-radius-lg: 28rpx;
  --fp-radius-xl: 36rpx;
  --fp-space-xs: 8rpx;
  --fp-space-sm: 16rpx;
  --fp-space-md: 24rpx;
  --fp-space-lg: 32rpx;
  --fp-space-xl: 44rpx;
  --fp-shadow-card: 0 10rpx 30rpx rgba(16, 24, 40, 0.08);
  --fp-shadow-soft: 0 4rpx 16rpx rgba(16, 24, 40, 0.05);

  /* Backward-compatible aliases for existing result/components styles. */
  --color-bg: var(--fp-bg);
  --color-surface: var(--fp-surface);
  --color-surface-elevated: var(--fp-surface);
  --color-surface-hover: var(--fp-surface-soft);
  --color-text-primary: var(--fp-text-primary);
  --color-text-secondary: var(--fp-text-secondary);
  --color-text-tertiary: var(--fp-text-tertiary);
  --color-border: var(--fp-border);
  --color-border-light: var(--fp-border);
  --color-accent: var(--fp-accent);
  --color-accent-soft: var(--fp-accent-soft);
  --color-accent-hover: var(--fp-accent-strong);
  --color-success: var(--fp-success);
  --color-success-soft: var(--fp-success-soft);
  --color-warning: var(--fp-warning);
  --color-warning-soft: var(--fp-warning-soft);
  --color-danger: var(--fp-danger);
  --color-danger-soft: var(--fp-danger-soft);
  --color-info: var(--fp-info);
  --color-info-soft: var(--fp-info-soft);
  --radius-sm: var(--fp-radius-sm);
  --radius-md: var(--fp-radius-md);
  --radius-lg: var(--fp-radius-lg);
  --radius-xl: var(--fp-radius-xl);
  --space-xs: var(--fp-space-xs);
  --space-sm: var(--fp-space-sm);
  --space-md: var(--fp-space-md);
  --space-lg: var(--fp-space-lg);
  --space-xl: var(--fp-space-xl);
  --space-2xl: 56rpx;
  --shadow-card: var(--fp-shadow-card);
  --shadow-raised: 0 14rpx 36rpx rgba(16, 24, 40, 0.12);
  --transition-fast: 150ms ease-out;
  --transition-normal: 220ms ease-out;

  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
  color: var(--fp-text-primary);
  background-color: var(--fp-bg);
  box-sizing: border-box;
}

view,
text,
input,
button,
textarea,
scroll-view {
  box-sizing: border-box;
}
