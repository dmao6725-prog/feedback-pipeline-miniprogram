/* run.wxss - analysis page polish */

.cleaning-row {
  min-height: 112rpx;
  margin-bottom: 28rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid var(--fp-border);
  border-radius: var(--fp-radius-md);
  background: var(--fp-surface-soft);
}

.cleaning-row switch {
  flex-shrink: 0;
}

.btn-run {
  width: 100%;
  height: 88rpx;
  margin-top: 6rpx;
  border-radius: 22rpx;
}

.upload-icon {
  width: 112rpx;
  height: 112rpx;
  display: block;
  margin: 0 auto 20rpx;
}

.file-status-image {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.progress-message {
  margin-top: 18rpx;
  color: var(--fp-text-secondary);
  font-size: 25rpx;
  line-height: 1.5;
}

.error-icon {
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: var(--fp-danger);
  background: #ffe4e1;
  font-size: 30rpx;
  font-weight: 800;
}
